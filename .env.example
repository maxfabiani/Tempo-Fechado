# Chave secreta do Flask (troque por um valor aleatório)
TEMPO_FECHADO_SECRET_KEY=coloque_uma_chave_aleatoria_aqui

# Chave JWT (se diferente da secret_key)
TEMPO_FECHADO_JWT_SECRET=

# Senhas dos usuários padrão (troque antes de liberar)
TEMPO_FECHADO_ADMIN_PASSWORD=trocar123
TEMPO_FECHADO_MAX_PASSWORD=trocar123
TEMPO_FECHADO_CONSULTA_PASSWORD=trocar123

# Para pular a criação dos usuários padrão, descomente:
# TEMPO_FECHADO_SKIP_DEFAULT_USERS=1

# Caminho raiz dos PDFs (tools/Script_Robo_Ponto_v6_PRO.py)
TEMPO_FECHADO_PASTA_RAIZ=%USERPROFILE%\ponto_pdfs

# E-mail do remetente filtro (Outlook)
TEMPO_FECHADO_REMETENTE_FILTRO=seu.email@empresa.com
